# EvalForge Configuration
# Copy to .env and fill in your API keys

# LLM Provider API Keys
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default provider
EVALFORGE_PROVIDER=deepseek
EVALFORGE_MODEL=deepseek-chat

# Storage
EVALFORGE_DB_PATH=evalforge_data/evalforge.db
EVALFORGE_DATA_DIR=evalforge_data

# Logging
EVALFORGE_LOG_LEVEL=INFO
